# Copy to .env and fill in.
# (No ANTHROPIC_API_KEY here — the LLM runs inside ElevenLabs ConvAI; the model
#  is chosen in the ElevenLabs dashboard, not via a key this backend reads.)
ELEVENLABS_AGENT_ID=
BUDDY_DB_PATH=./buddy.db
BUDDY_PORT=8765
# Path to the separate hu-poker-trainer Python repo (required for HU lookups; see README).
HU_TRAINER_PATH=~/hu-poker-trainer
LOG_LEVEL=INFO

# ElevenLabs API key for one-shot agent sync via scripts/sync_agent.py.
# Get one at https://elevenlabs.io/app/settings/api-keys with
# Conversational AI: Create + Edit permissions.
ELEVENLABS_API_KEY=

# These get filled in automatically by sync_agent.py — leave empty.
ELEVENLABS_TOOL_IDS=

# Random string. Paste the same value into every ElevenLabs tool's
# X-Buddy-Secret header. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BUDDY_SHARED_SECRET=
